{
  "info": {
    "name": "GitHub Trends API",
    "description": "API completa: Trends + User Tracking + Enterprise Repo Monitoring",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "apiKey", "value": "your-api-key" },
    { "key": "email", "value": "test@example.com" },
    { "key": "password", "value": "Test1234!" },
    { "key": "verificationToken", "value": "" },
    { "key": "resetToken", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /auth/register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json", "type": "text" }],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}" }
          }
        },
        {
          "name": "GET /auth/verify-email",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/auth/verify-email?token={{verificationToken}}", "host": ["{{baseUrl}}"], "path": ["auth", "verify-email"], "query": [{ "key": "token", "value": "{{verificationToken}}" }] }
          }
        },
        {
          "name": "POST /auth/login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json", "type": "text" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}" }
          }
        },
        {
          "name": "POST /auth/refresh",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth", "refresh"] }
          }
        },
        {
          "name": "POST /auth/logout",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth", "logout"] }
          }
        },
        {
          "name": "POST /auth/forgot-password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json", "type": "text" }],
            "url": { "raw": "{{baseUrl}}/auth/forgot-password", "host": ["{{baseUrl}}"], "path": ["auth", "forgot-password"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{email}}\"\n}" }
          }
        },
        {
          "name": "POST /auth/reset-password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json", "type": "text" }],
            "url": { "raw": "{{baseUrl}}/auth/reset-password", "host": ["{{baseUrl}}"], "path": ["auth", "reset-password"] },
            "body": { "mode": "raw", "raw": "{\n  \"token\": \"{{resetToken}}\",\n  \"password\": \"{{password}}\"\n}" }
          }
        }
      ]
    },
    {
      "name": "User Profile",
      "item": [
        {
          "name": "GET /me",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/me", "host": ["{{baseUrl}}"], "path": ["me"] }
          }
        }
      ]
    },
    {
      "name": "GitHub Token",
      "item": [
        {
          "name": "POST /me/github-token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json", "type": "text" }],
            "url": { "raw": "{{baseUrl}}/me/github-token", "host": ["{{baseUrl}}"], "path": ["me", "github-token"] },
            "body": { "mode": "raw", "raw": "{\n  \"token\": \"ghp_xxxx\"\n}" }
          }
        },
        {
          "name": "GET /me/github-token",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/me/github-token", "host": ["{{baseUrl}}"], "path": ["me", "github-token"] }
          }
        }
      ]
    },
    {
      "name": "Tracked Repos",
      "item": [
        {
          "name": "GET /me/repos",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/me/repos", "host": ["{{baseUrl}}"], "path": ["me", "repos"] }
          }
        },
        {
          "name": "POST /me/repos (add)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json", "type": "text" }],
            "url": { "raw": "{{baseUrl}}/me/repos", "host": ["{{baseUrl}}"], "path": ["me", "repos"] },
            "body": { "mode": "raw", "raw": "{\n  \"fullName\": \"owner/repo\"\n}" }
          }
        },
        {
          "name": "DELETE /me/repos/:id",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/me/repos/1", "host": ["{{baseUrl}}"], "path": ["me", "repos", "1"] }
          }
        }
      ]
    },
    {
      "name": "Repo Data",
      "item": [
        {
          "name": "GET /me/repos/:id/history",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/me/repos/1/history", "host": ["{{baseUrl}}"], "path": ["me", "repos", "1", "history"] }
          }
        },
        {
          "name": "GET /me/repos/:id/commits",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/me/repos/1/commits?limit=10", "host": ["{{baseUrl}}"], "path": ["me", "repos", "1", "commits"], "query": [{ "key": "limit", "value": "10" }] }
          }
        },
        {
          "name": "GET /me/repos/:id/prs",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/me/repos/1/prs", "host": ["{{baseUrl}}"], "path": ["me", "repos", "1", "prs"] }
          }
        },
        {
          "name": "GET /me/repos/:id/prs?state=OPEN",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/me/repos/1/prs?state=OPEN", "host": ["{{baseUrl}}"], "path": ["me", "repos", "1", "prs"], "query": [{ "key": "state", "value": "OPEN" }] }
          }
        },
        {
          "name": "GET /me/repos/:id/issues",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/me/repos/1/issues", "host": ["{{baseUrl}}"], "path": ["me", "repos", "1", "issues"] }
          }
        },
        {
          "name": "GET /me/repos/:id/branches",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/me/repos/1/branches", "host": ["{{baseUrl}}"], "path": ["me", "repos", "1", "branches"] }
          }
        },
        {
          "name": "GET /me/repos/:id/releases",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/me/repos/1/releases", "host": ["{{baseUrl}}"], "path": ["me", "repos", "1", "releases"] }
          }
        },
        {
          "name": "GET /me/repos/:id/activity",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/me/repos/1/activity", "host": ["{{baseUrl}}"], "path": ["me", "repos", "1", "activity"] }
          }
        },
        {
          "name": "GET /me/repos/:id/scan-history",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/me/repos/1/scan-history", "host": ["{{baseUrl}}"], "path": ["me", "repos", "1", "scan-history"] }
          }
        }
      ]
    },
    {
      "name": "Repo Refresh",
      "item": [
        {
          "name": "POST /me/repos/:id/refresh-commits",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/me/repos/1/refresh-commits", "host": ["{{baseUrl}}"], "path": ["me", "repos", "1", "refresh-commits"] }
          }
        },
        {
          "name": "POST /me/repos/:id/refresh-all",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/me/repos/1/refresh-all", "host": ["{{baseUrl}}"], "path": ["me", "repos", "1", "refresh-all"] }
          }
        }
      ]
    },
    {
      "name": "Search",
      "item": [
        {
          "name": "GET /search/kubernetes",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-api-key", "value": "{{apiKey}}", "type": "text" }],
            "url": { "raw": "{{baseUrl}}/search/kubernetes", "host": ["{{baseUrl}}"], "path": ["search", "kubernetes"] }
          }
        },
        {
          "name": "GET /search/react?first=25",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-api-key", "value": "{{apiKey}}", "type": "text" }],
            "url": { "raw": "{{baseUrl}}/search/react?first=25", "host": ["{{baseUrl}}"], "path": ["search", "react"], "query": [{ "key": "first", "value": "25" }] }
          }
        }
      ]
    },
    {
      "name": "Trends",
      "item": [
        {
          "name": "GET /trends",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-api-key", "value": "{{apiKey}}", "type": "text" }],
            "url": { "raw": "{{baseUrl}}/trends", "host": ["{{baseUrl}}"], "path": ["trends"] }
          }
        },
        {
          "name": "GET /trends?sort=score",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-api-key", "value": "{{apiKey}}", "type": "text" }],
            "url": { "raw": "{{baseUrl}}/trends?sort=score", "host": ["{{baseUrl}}"], "path": ["trends"], "query": [{ "key": "sort", "value": "score" }] }
          }
        },
        {
          "name": "GET /trends/stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-api-key", "value": "{{apiKey}}", "type": "text" }],
            "url": { "raw": "{{baseUrl}}/trends/stats", "host": ["{{baseUrl}}"], "path": ["trends", "stats"] }
          }
        },
        {
          "name": "GET /trends/report",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-api-key", "value": "{{apiKey}}", "type": "text" }],
            "url": { "raw": "{{baseUrl}}/trends/report", "host": ["{{baseUrl}}"], "path": ["trends", "report"] }
          }
        }
      ]
    }
  ]
}
