{
  "info": {
    "name": "GitHub Analytics API",
    "description": "API para busqueda de repos en GitHub + Trends collector + Auth de usuarios",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "apiKey",
      "value": "your-api-key"
    },
    {
      "key": "email",
      "value": "test@example.com"
    },
    {
      "key": "password",
      "value": "Test1234!"
    },
    {
      "key": "verificationToken",
      "value": ""
    },
    {
      "key": "resetToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /auth/register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            }
          }
        },
        {
          "name": "GET /auth/verify-email",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/auth/verify-email?token={{verificationToken}}",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "verify-email"],
              "query": [
                {
                  "key": "token",
                  "value": "{{verificationToken}}"
                }
              ]
            }
          }
        },
        {
          "name": "POST /auth/login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            }
          }
        },
        {
          "name": "GET /me",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/me",
              "host": ["{{baseUrl}}"],
              "path": ["me"]
            }
          }
        },
        {
          "name": "POST /auth/refresh",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "refresh"]
            }
          }
        },
        {
          "name": "POST /auth/logout",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "logout"]
            }
          }
        },
        {
          "name": "POST /auth/forgot-password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/forgot-password",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "forgot-password"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\"\n}"
            }
          }
        },
        {
          "name": "POST /auth/reset-password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/reset-password",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "reset-password"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{resetToken}}\",\n  \"password\": \"{{password}}\"\n}"
            }
          }
        },
        {
          "name": "GET /auth/debug/tokens (dev only)",
          "request": {
            "method": "GET",
            "description": "Dev only. Devuelve verification_token y password_reset_token para un usuario sin depender de que llegue el email. Usar cuando el SMTP no entrega correos.",
            "url": {
              "raw": "{{baseUrl}}/auth/debug/tokens?email={{email}}",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "debug", "tokens"],
              "query": [
                {
                  "key": "email",
                  "value": "{{email}}"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Search",
      "item": [
        {
          "name": "GET /search/:keyword",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{apiKey}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/search/opentelemetry",
              "host": ["{{baseUrl}}"],
              "path": ["search", "opentelemetry"]
            }
          }
        },
        {
          "name": "GET /search/kubernetes",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{apiKey}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/search/kubernetes",
              "host": ["{{baseUrl}}"],
              "path": ["search", "kubernetes"]
            }
          }
        },
        {
          "name": "GET /search/react?first=25",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{apiKey}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/search/react?first=25",
              "host": ["{{baseUrl}}"],
              "path": ["search", "react"],
              "query": [
                {
                  "key": "first",
                  "value": "25"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Trends",
      "item": [
        {
          "name": "GET /trends",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{apiKey}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/trends",
              "host": ["{{baseUrl}}"],
              "path": ["trends"]
            }
          }
        },
        {
          "name": "GET /trends?keyword=kubernetes",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{apiKey}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/trends?keyword=kubernetes",
              "host": ["{{baseUrl}}"],
              "path": ["trends"],
              "query": [
                {
                  "key": "keyword",
                  "value": "kubernetes"
                }
              ]
            }
          }
        },
        {
          "name": "GET /trends?language=Go",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{apiKey}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/trends?language=Go",
              "host": ["{{baseUrl}}"],
              "path": ["trends"],
              "query": [
                {
                  "key": "language",
                  "value": "Go"
                }
              ]
            }
          }
        },
        {
          "name": "GET /trends?sort=score&limit=10",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{apiKey}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/trends?sort=score&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["trends"],
              "query": [
                {
                  "key": "sort",
                  "value": "score"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "GET /trends?sort=score&page=1&repoLimit=5",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{apiKey}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/trends?sort=score&page=1&repoLimit=5",
              "host": ["{{baseUrl}}"],
              "path": ["trends"],
              "query": [
                {
                  "key": "sort",
                  "value": "score"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "repoLimit",
                  "value": "5"
                }
              ]
            }
          }
        },
        {
          "name": "GET /trends/stats",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{apiKey}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/trends/stats",
              "host": ["{{baseUrl}}"],
              "path": ["trends", "stats"]
            }
          }
        },
        {
          "name": "GET /trends/report",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{apiKey}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/trends/report",
              "host": ["{{baseUrl}}"],
              "path": ["trends", "report"]
            }
          }
        }
      ]
    }
  ]
}
